# --- SHASHOF OYNALI TUGMALAR ---

# Admin boshqaruv paneli
def get_admin_menu():
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [InlineKeyboardButton(text="➕ Kino qo'shish", callback_data="admin_add")],
            [InlineKeyboardButton(text="➕ Yangi Kanal qo'shish", callback_data="add_channel")],
            [InlineKeyboardButton(text="❌ Kanalni o'chirish", callback_data="del_channel")],
            [InlineKeyboardButton(text="📊 Statistika", callback_data="admin_stat")]
        ]
    )

# Dinamik ravishda barcha majburiy kanallar ro'yxatini chiqarish
def get_sub_keyboard():
    cursor.execute("SELECT link, nomi FROM kanallar")
    kanallar = cursor.fetchall()
    
    keyboard = []
    # Har bir kanalni tugma qilib ro'yxatga qo'shish
    for i, kanal in enumerate(kanallar, start=1):
        keyboard.append([InlineKeyboardButton(text=f"📢 {kanal[1]}", url=kanal[0])])
        
    # Eng pastiga tekshirish tugmasini qo'shish
    keyboard.append([InlineKeyboardButton(text="✅ Tekshirish", callback_data="check_sub")])
    return InlineKeyboardMarkup(inline_keyboard=keyboard)

# Barcha kanallarga a'zolikni tekshirish funksiyasi
async def check_subscription(user_id: int) -> bool:
    if user_id == ADMIN_ID: 
        return True
    cursor.execute("SELECT kanal_id FROM kanallar")
    kanallar = cursor.fetchall()
    
    if not kanallar: # Agar bazada hali kanal bo'lmasa, o'tkazib yuboradi
        return True
        
    for kanal in kanallar:
        try:
            member = await bot.get_chat_member(chat_id=kanal[0], user_id=user_id)
            if member.status not in ["member", "administrator", "creator"]:
                return False
        except Exception as e:
            print(f"❌ Kanal tekshirishda xato ({kanal[0]}): {e}")
            return False # Kanal topilmasa yoki bot admin bo'lmasa ham o'tkazmaydi
    return True

# --- BOT LOGIKASI ---

@dp.message(F.text == "/start")
async def start_cmd(message: Message):
    try:
        cursor.execute("INSERT OR IGNORE INTO foydalanuvchilar VALUES (?)", (message.from_user.id,))
        db.commit()
    except: pass

    if message.from_user.id == ADMIN_ID:
        return await message.answer_photo(
            photo=MENU_IMAGE,
            caption="👋 **Xush kelibsiz, Admin!**\n\nKanallar ro'yxatini shakllantirish va botni boshqarish paneli:",
            reply_markup=get_admin_menu(),
            parse_mode="Markdown"
        )

    # Foydalanuvchini ro'yxatdagi hamma kanalga tekshirish
    if not await check_subscription(message.from_user.id):
        await message.answer_photo(
            photo=MENU_IMAGE,
            caption="⚠️ **Botdan foydalanish uchun quyidagi barcha kanallarga a'zo bo'lishingiz shart!**\n\nKanallarga kirib a'zo bo'ling va 'Tekshirish' tugmasini bosing.",
            reply_markup=get_sub_keyboard(),
            parse_mode="Markdown"
        )
    else:
        await message.answer_photo(
            photo=MENU_IMAGE,
            caption="👋 **Assalomu alaykum!**\n\nKino ko'rish uchun uning **kodini** yuboring.",
            parse_mode="Markdown"
        )

@dp.callback_query(F.data == "check_sub")
async def check_callback(callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    if await check_subscription(user_id):
        await callback_query.message.delete()
        await bot.send_message(chat_id=user_id, text="✅ Obuna tasdiqlandi! Kino **kodini** yuborishingiz mumkin.")
    else:
        await callback_query.answer("❌ Siz hali barcha kanallarga a'zo bo'lmagansiz!", show_alert=True)

# KINO QIDRISH
@dp.message(F.text.isdigit())
async def get_video(message: Message):
    if not await check_subscription(message.from_user.id):
        return await message.answer("⚠️ Botdan foydalanish uchun avval hamma kanallarga a'zo bo'ling:", reply_markup=get_sub_keyboard())

    cursor.execute("SELECT file_id FROM kinolar WHERE kod = ?", (message.text,))
    result = cursor.fetchone()
    if result:
        await message.reply_video(video=result[0], caption=f"🎬 Kino kodi: {message.text}")
    else:
        await message.reply("🔍 Afsuski, bu kod bilan kino topilmadi.")

