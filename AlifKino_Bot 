@dp.callback_query(F.data == "admin_stat")
async def admin_stat(call: CallbackQuery):
    cursor.execute("SELECT COUNT(*) FROM foydalanuvchilar")
    u_count = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM kinolar")
    k_count = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM kanallar")
    ch_count = cursor.fetchone()[0]
    await call.message.answer_photo(
        photo=MENU_IMAGE,
        caption=f"📊 **Statistika:**\n\n👥 Foydalanuvchilar: {u_count} ta\n🎬 Kinolar soni: {k_count} ta\n📢 Homiy kanallar: {ch_count} ta",
        parse_mode="Markdown",
        reply_markup=get_admin_menu()
    )
    await call.answer()

