    await state.update_data(id=message.text)
    await message.answer("Kanal havolasini (linkini) yuboring (https://t.me/...):")
    await state.set_state(AdminStates.k_link_kutish)

@dp.message(AdminStates.k_link_kutish)
async def process_k_link(message: Message, state: FSMContext):
    await state.update_data(link=message.text)
    await message.answer("Tugmada ko'rinadigan nom kiriting (masalan: 1-Kanal):")
    await state.set_state(AdminStates.k_nomi_kutish)

@dp.message(AdminStates.k_nomi_kutish)
async def process_k_nomi(message: Message, state: FSMContext):
    data = await state.get_data()
    cursor.execute("INSERT OR REPLACE INTO kanallar VALUES (?, ?, ?)", (data.get("id"), data.get("link"), message.text))
    db.commit()
    await message.answer_photo(
        photo=MENU_IMAGE,
        caption="✅ **Yangi kanal majburiy obuna ro'yxatiga muvaffaqiyatli qo'shildi!**",
        reply_markup=get_admin_menu(),
        parse_mode="Markdown"
    )
    await state.clear()

# 2. Kanalni ro'yxatdan o'chirish
@dp.callback_query(F.data == "del_channel")
async def del_channel_start(call: CallbackQuery, state: FSMContext):
    cursor.execute("SELECT kanal_id, nomi FROM kanallar")
    kanallar = cursor.fetchall()
    if not kanallar:
        return await call.answer("O'chirish uchun kanallar ro'yxati bo'sh!", show_alert=True)
        
    matn = "O'chirmoqchi bo'lgan kanalingiz ID sini nusxalab qayta yuboring:\n\n"
    for k in kanallar:
        matn += f"📌 {k[1]} -> `{k[0]}`\n"
    await call.message.answer(matn, parse_mode="Markdown")
    await state.set_state(AdminStates.del_kutish)
    await call.answer()

@dp.message(AdminStates.del_kutish)
async def process_del(message: Message, state: FSMContext):
    cursor.execute("DELETE FROM kanallar WHERE kanal_id=?", (message.text,))
    db.commit()
    await message.answer_photo(
        photo=MENU_IMAGE,
        caption="❌ **Kanal ro'yxatdan o'chirib tashlandi!**",
        reply_markup=get_admin_menu(),
        parse_mode="Markdown"
    )
    await state.clear()

